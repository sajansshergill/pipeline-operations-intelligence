{
    "expectation_suite_name": "vertex_job_events.critical",
    "expectations": [
      {
        "expectation_type": "expect_column_to_exist",
        "kwargs": { "column": "event_id" }
      },
      {
        "expectation_type": "expect_column_values_to_not_be_null",
        "kwargs": { "column": "event_id" }
      },
      {
        "expectation_type": "expect_column_values_to_be_unique",
        "kwargs": { "column": "event_id" }
      },
      {
        "expectation_type": "expect_column_values_to_not_be_null",
        "kwargs": { "column": "tenant_id" }
      },
      {
        "expectation_type": "expect_column_values_to_be_in_set",
        "kwargs": {
          "column": "status",
          "value_set": ["SUCCEEDED", "FAILED", "RUNNING", "QUEUED", "CANCELLED"]
        }
      },
      {
        "expectation_type": "expect_column_values_to_be_between",
        "kwargs": {
          "column": "cost_usd",
          "min_value": 0,
          "max_value": 10000
        }
      },
      {
        "expectation_type": "expect_column_values_to_be_between",
        "kwargs": {
          "column": "duration_seconds",
          "min_value": 0,
          "max_value": 172800
        }
      },
      {
        "expectation_type": "expect_column_values_to_be_between",
        "kwargs": {
          "column": "gpu_hours",
          "min_value": 0,
          "max_value": 1000
        }
      },
      {
        "expectation_type": "expect_column_values_to_not_be_null",
        "kwargs": { "column": "started_at" }
      },
      {
        "expectation_type": "expect_column_values_to_be_in_set",
        "kwargs": {
          "column": "job_type",
          "value_set": ["TRAINING", "BATCH_PREDICTION", "PIPELINE_RUN"]
        }
      }
    ],
    "meta": {
      "great_expectations_version": "0.18.15"
    }
  }